colors:
    .word 0x00FFFFFF   # 0 = White
    .word 0x00000000   # 1 = Black
    .word 0x0066FF00   # 2 = Green

.text

li a0, LED_MATRIX_0_BASE
li a1, LED_MATRIX_0_WIDTH    # 35
li a2, LED_MATRIX_0_HEIGHT

# Load color values
la t6, colors
lw s2, 0(t6)    # white
lw s3, 4(t6)    # black
lw s4, 8(t6)    # green

la a5, maze     # pointer to current byte

li t3, 0        # row = 0

row_loop:
    li t4, 0    # col = 0

    col_loop:
        # Load byte value (0, 1, or 2)
        lbu t0, 0(a5)
        addi a5, a5, 1      # advance byte pointer

        # Compute pixel address = BASE + (row*35 + col) * 4
        mul t5, t3, a1
        add t5, t5, t4
        slli t5, t5, 2
        add t5, t5, a0

        # Pick color based on value
        li t1, 2
        beq t0, t1, paint_green
        li t1, 1
        beq t0, t1, paint_black

        # paint white
        sw s2, 0(t5)
        j next_col

    paint_black:
        sw s3, 0(t5)
        j next_col

    paint_green:
        sw s4, 0(t5)

    next_col:
        addi t4, t4, 1
        li t1, 35
        blt t4, t1, col_loop

    addi t3, t3, 1
    li t1, 25
    blt t3, t1, row_loop

done:
    nop
