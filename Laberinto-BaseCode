.data

emoji:

.word 0x00EE4B2B,0x0066FF00,0x00A7C7E7,0x00FFFFFF,0x00000000
#     Red        Green      Blue       White      Black

.text

li a0 LED_MATRIX_0_BASE #Base address of the LED matrix

li a1 LED_MATRIX_0_WIDTH #35*4=140

li a2 LED_MATRIX_0_HEIGHT #25

la a3, emoji

lw t1, 12(a3)    #White
lw t2, 16(a3)    #Black
lw a6, 4(a3)     #Green
li t3, 1         #Row = 1
li a4, 34        # LED Matrix width - 1 = 34
li a5, 24        #LED Matrix height - 1 = 24

#Create the White Background with Black Border

outer_loop:
    bge t3, a5, done
    li t4, 1   #starts in col 1 
    inner_loop:
        bge t4, a4, next_row
        #BASE + (row × 140) + (col × 4)
        
        mul t5, t3, a1        #Row * width
        add t5, t5, t4        #Row * width + col
        slli t5, t5, 2
        add t5, t5, a0
        
        sw t1, 0(t5)
        
        addi t4, t4, 1
        j inner_loop
        
        next_row:
            addi t3,t3,1
            j outer_loop     

done:

#Green pixel - End of Game
sw a6, 984(a0)


# Vertical Lines------------------------------- 
